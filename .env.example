SECRET_KEY=your-64-char-random-hex-secret-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
DATABASE_URL=sqlite:///./groupthink.db
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
AI_CONTEXT_WINDOW=20

# Gmail — for password reset emails
# Use a Gmail App Password (not your real password)
# Enable at: myaccount.google.com > Security > 2-Step Verification > App passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google OAuth — for "Sign in with Google"
# Create at: console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Public URL of your app (used in reset email links)
BASE_URL=http://localhost:8000
