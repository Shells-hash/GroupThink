SECRET_KEY=your-64-char-random-hex-secret-key-here
DATABASE_URL=sqlite:///./groupthink.db
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
AI_CONTEXT_WINDOW=20

# ── AI Provider ─────────────────────────────────────────────────────────────
# Set MODEL_PROVIDER to one of: anthropic | groq | together | ollama
MODEL_PROVIDER=groq

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq (free Llama hosting) — https://console.groq.com
GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile       # default
# GROQ_FAST_MODEL=llama-3.1-8b-instant     # default

# Together AI — https://api.together.xyz
# TOGETHER_API_KEY=your-key-here
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Ollama (local, free) — run: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# Gmail — for password reset emails
# Use a Gmail App Password (not your real password)
# Enable at: myaccount.google.com > Security > 2-Step Verification > App passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google OAuth — for "Sign in with Google"
# Create at: console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Public URL of your app (used in reset email links)
BASE_URL=http://localhost:8000
